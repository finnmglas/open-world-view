# responsible: finn
# goal: reloading dev fe for local dev

FROM node:20-alpine

WORKDIR /app
RUN corepack enable

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1

EXPOSE 3000

# pnpm install runs at container start (not build time) so new host deps are picked up
CMD ["sh", "-c", "pnpm install && pnpm dev"]
